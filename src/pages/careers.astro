---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Careers" description="Grow your career with a fourth-generation West Michigan landscape company.">
  <section class="section">
    <div class="container" style="max-width: 760px;">
      <p class="eyebrow">Careers</p>
      <h1>Grow with us</h1>
      <p>
        We're always looking for people who love working outdoors and take pride in
        their craft — from designers and crew leads to garden center staff and
        seasonal help.
      </p>

      <!-- TODO: pull open roles from a Content Collection; add /careers application
           form (interactive → job_applications table) once role list is finalized. -->
      <h2>Open positions</h2>
      <p>Positions are posted seasonally. Check back soon or send us your information.</p>

      <a href="/contact" class="btn btn--primary">Express interest</a>
    </div>
  </section>
</BaseLayout>
